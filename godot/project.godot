config_version=5

[application]

config/name="CoreSapian"
config/description="Interactive rune puzzle and core truths experience"
run/main_scene="res://scenes/temple_explorer/temple_explorer.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[display]

